{
  "name": "hesm-app",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "import-socios": "node scripts/build-socios-data.cjs",
    "import-cartilla": "node scripts/build-cartilla-from-hesm.cjs",
    "prestart": "node scripts/build-socios-data.cjs",
    "start": "expo start",
    "android": "expo run:android",
    "build:android:apk": "node scripts/build-socios-data.cjs && cd android && gradlew.bat assembleRelease",
    "serve:apk": "npx --yes serve android/app/build/outputs/apk/release -l 9876",
    "qr:apk": "node scripts/generate-apk-qr.cjs",
    "eas:android:preview": "eas build --platform android --profile preview",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.106.0",
    "eas-cli": "^18.4.0",
    "expo": "~54.0.0",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "0.577.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "7.71.2",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "babel-preset-expo": "~54.0.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "patch-package": "^8.0.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.35.1",
    "typescript": "5.9.3"
  }
}
